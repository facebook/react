{
  "name": "flight-ssr-bench",
  "version": "0.1.0",
  "private": true,
  "devEngines": {
    "node": "20.x || 22.x"
  },
  "dependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-react": "^7.22.5",
    "babel-loader": "^8.2.3",
    "react": "experimental",
    "react-dom": "experimental",
    "react-server-dom-webpack": "experimental",
    "webpack": "^5.64.4"
  },
  "scripts": {
    "prebuild": "cp -r ../../build/oss-experimental/* ./node_modules/",
    "prebench": "cp -r ../../build/oss-experimental/* ./node_modules/",
    "build": "NODE_ENV=production node render.js",
    "start": "NODE_ENV=production node render.js && npx -y serve build",
    "bench": "NODE_ENV=production node bench.js",
    "bench:profile": "NODE_ENV=production node bench.js --profile"
  }
}
